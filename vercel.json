{
  "github": {
    "silent": true
  },
  "headers": [
    {
      "source": "/news/:slug*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=2592000, max-age=604800, stale-while-revalidate=86400"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=2592000"
        }
      ]
    },
    {
      "source": "/articles/:slug*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=2592000, max-age=604800, stale-while-revalidate=86400"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=2592000"
        }
      ]
    }
  ]
}
