{
  "github": {
    "silent": true
  },
  "headers": [
    {
      "source": "/news",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, max-age=300, stale-while-revalidate=60"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=3600"
        }
      ]
    },
    {
      "source": "/articles",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, max-age=300, stale-while-revalidate=60"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=3600"
        }
      ]
    },
    {
      "source": "/news/:slug*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=2592000, max-age=1800, stale-while-revalidate=60"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=1800, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/articles/:slug*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=2592000, max-age=1800, stale-while-revalidate=60"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=1800, stale-while-revalidate=60"
        }
      ]
    }
  ]
}
