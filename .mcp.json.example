{
  "mcpServers": {
    "newsletter-ai": {
      "command": "__PROJECT_DIR__/node_modules/.bin/tsx",
      "args": ["__PROJECT_DIR__/src/mcp/index.ts"],
      "cwd": "__PROJECT_DIR__",
      "env": {
        "PROJECT_DIR": "__PROJECT_DIR__",
        "OUTPUT_PATH": "__MOTYL_DEV_DIR__/news/2026",
        "NARRATOR_PERSONA": "Scott Hanselman"
      }
    }
  }
}
