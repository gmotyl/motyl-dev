# ===========================
# Postiz — motyl.dev instance
# ===========================
# Copy to .env and fill in values
# NEVER commit .env to git

# === URLs ===
# Replace nas-ip with your NAS IP or hostname (e.g. 192.168.1.100)
MAIN_URL=http://nas-ip:4007
FRONTEND_URL=http://nas-ip:4007
NEXT_PUBLIC_BACKEND_URL=http://nas-ip:4007/api
BACKEND_INTERNAL_URL=http://localhost:3000

# === Auth ===
# Generate with: openssl rand -hex 32
JWT_SECRET=

# === Database ===
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://postiz-user:${POSTGRES_PASSWORD}@postiz-postgres:5432/postiz-db

# === Redis ===
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@postiz-redis:6379

# === Temporal ===
TEMPORAL_ADDRESS=temporal:7233

# === General ===
IS_GENERAL=true
DISABLE_REGISTRATION=false
RUN_CRON=true
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# ===========================
# Social Media API Keys
# ===========================
# Get credentials from each platform's developer portal

# X (Twitter)
# https://developer.x.com/en/portal/projects-and-apps
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Bluesky
# No API key needed — uses AT Protocol (email + password in Postiz UI)

# Instagram / Threads (via Meta)
# https://developers.facebook.com/apps/
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# TikTok
# https://developers.tiktok.com/
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Reddit
# https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ===========================
# Email (optional but recommended)
# ===========================
# https://resend.com/
RESEND_API_KEY=
